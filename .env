# App
APP_PORT=8080

# Database
DB_HOST=postgres
DB_PORT=5432
DB_USER=user
DB_PASSWORD=password
DB_NAME=notificationdb
DB_SSL_MODE=disable

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# Provider
PROVIDER_URL=http://fakewebhook:8081
PROVIDER_AUTH_KEY=secret
PROVIDER_TIMEOUT=10s
PROVIDER_MAX_RETRIES=3

# Worker
WORKER_CONCURRENCY=5
WORKER_RATE_LIMIT=100
WORKER_MAX_RETRIES=3
WORKER_RETRY_TTL=30s
WORKER_RECOVERY_INTERVAL=30s

# Jaeger
JAEGER_ENDPOINT=jaeger:4318
