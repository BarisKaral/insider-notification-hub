# App
APP_PORT=8080

# Database (use "postgres" for Docker, "localhost" for local dev)
DB_HOST=localhost
DB_PORT=5432
DB_USER=user
DB_PASSWORD=password
DB_NAME=notificationdb
DB_SSL_MODE=disable

# RabbitMQ (use "rabbitmq" for Docker, "localhost" for local dev)
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Provider (get your unique URL from https://webhook.site)
PROVIDER_URL=https://webhook.site/your-uuid-here
PROVIDER_AUTH_KEY=secret
PROVIDER_TIMEOUT=10s
PROVIDER_MAX_RETRIES=3

# Worker
WORKER_CONCURRENCY=5
WORKER_RATE_LIMIT=100
WORKER_MAX_RETRIES=3
WORKER_RETRY_TTL=30s
WORKER_RECOVERY_INTERVAL=30s

# Jaeger (use "jaeger:4318" for Docker, "localhost:4318" for local dev)
JAEGER_ENDPOINT=localhost:4318
